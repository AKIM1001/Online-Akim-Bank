services:
  eureka-server:
    image: ghcr.io/akim1001/online-akim-bank/eureka-server:v1.0.0
    environment:
      - SPRING_PROFILES_ACTIVE=prod
    networks:
      - "online-akim-bank-network"

  api-gateway:
    image: ghcr.io/akim1001/online-akim-bank/api-gateway:v1.0.0
    environment:
      - SPRING_PROFILES_ACTIVE=prod
    env_file:
      - api-gateway/.env.prod
    depends_on:
      - eureka-server
    networks:
      - "online-akim-bank-network"

  auth-service:
    image: ghcr.io/akim1001/online-akim-bank/auth-service:v1.0.0
    environment:
      - SPRING_PROFILES_ACTIVE=prod
    env_file:
      - auth-service/.env.prod
    depends_on:
      - eureka-server
    networks:
      - "online-akim-bank-network"

  user-service:
    image: ghcr.io/akim1001/online-akim-bank/user-service:v1.0.0
    environment:
      - SPRING_PROFILES_ACTIVE=prod
    env_file:
      - user-service/.env.prod
    depends_on:
      - eureka-server
    networks:
      - "online-akim-bank-network"

  account-service:
    image: ghcr.io/akim1001/online-akim-bank/account-service:v1.0.0
    environment:
      - SPRING_PROFILES_ACTIVE=prod
    env_file:
      - account-service/.env.prod
    depends_on:
      - eureka-server
    networks:
      - "online-akim-bank-network"

  card-service:
    image: ghcr.io/akim1001/online-akim-bank/card-service:v1.0.0
    environment:
      - SPRING_PROFILES_ACTIVE=prod
    env_file:
      - card-service/.env.prod
    depends_on:
      - eureka-server
    networks:
      - "online-akim-bank-network"

  admin-service:
    image: ghcr.io/akim1001/online-akim-bank/admin-service:v1.0.0
    environment:
      - SPRING_PROFILES_ACTIVE=prod
    env_file:
      - admin-service/.env.prod
    depends_on:
      - admin-server
    networks:
      - "online-akim-bank-network"

  document-service:
    image: ghcr.io/akim1001/online-akim-bank/document-service:v1.0.0
    environment:
      - SPRING_PROFILES_ACTIVE=prod
    env_file:
      - document-service/.env.prod
    depends_on:
      - document-server
    networks:
      - "online-akim-bank-network"

  loan-service:
    image: ghcr.io/akim1001/online-akim-bank/loan-service:v1.0.0
    environment:
      - SPRING_PROFILES_ACTIVE=prod
    env_file:
      - loan-service/.env.prod
    depends_on:
      - loan-server
    networks:
      - "online-akim-bank-network"

  payment-service:
    image: ghcr.io/akim1001/online-akim-bank/payment-service:v1.0.0
    environment:
      - SPRING_PROFILES_ACTIVE=prod
    env_file:
      - payment-service/.env.prod
    depends_on:
      - payment-server
    networks:
      - "online-akim-bank-network"

  transaction-service:
    image: ghcr.io/akim1001/online-akim-bank/transaction-service:v1.0.0
    environment:
      - SPRING_PROFILES_ACTIVE=prod
    env_file:
      - transaction-service/.env.prod
    depends_on:
      - transaction-server
    networks:
      - "online-akim-bank-network"

  vault:
    image: hashicorp/vault:1.19.5
    container_name: vault-dev
    ports:
      - "8200:8200"
    environment:
      VAULT_DEV_ROOT_TOKEN_ID: hvstoken123
      VAULT_DEV_LISTEN_ADDRESS: "0.0.0.0:8200"
      VAULT_API_ADDR: "http://127.0.0.1:8200"
    cap_add:
      - IPC_LOCK
    volumes:
      - vault-data:/vault/file

  zookeeper:
    image: confluentinc/cp-zookeeper:7.6.0
    container_name: zookeeper
    ports:
      - "2181:2181"
    environment:
      ZOOKEEPER_CLIENT_PORT: 2181
      ZOOKEEPER_TICK_TIME: 2000

  kafka:
    image: confluentinc/cp-kafka:7.6.0
    container_name: kafka
    depends_on:
      - zookeeper
    ports:
      - "9092:9092"
    environment:
      KAFKA_BROKER_ID: 1
      KAFKA_ZOOKEEPER_CONNECT: zookeeper:2181
      KAFKA_ADVERTISED_LISTENERS: PLAINTEXT://localhost:9092
      KAFKA_LISTENER_SECURITY_PROTOCOL_MAP: PLAINTEXT:PLAINTEXT
      KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR: 1

  minio:
    image: minio/minio
    container_name: minio
    ports:
      - "9000:9000"
      - "9001:9001"
    environment:
      MINIO_ROOT_USER: admin
      MINIO_ROOT_PASSWORD: secret123456
    volumes:
      - ~/minio/data:/data
    command: server --console-address :9001 /data

  postgres:
    image: postgres:15
    container_name: user-info
    environment:
      - POSTGRES_USER=admin
      - POSTGRES_PASSWORD=secret
      - POSTGRES_DB=users
    ports:
      - "5432:5432"
    restart: unless-stopped

  cassandra:
    image: cassandra:latest
    container_name: online-akim-bank-cassandra
    volumes:
      - cassandra_data:/var/lib/cassandra
    environment:
      - CASSANDRA_CLUSTER_NAME=online-akim-bank-cluster
      - CASSANDRA_DC=dc1
      - CASSANDRA_RACK=rack1
      - CASSANDRA_ENDPOINT_SNITCH=GossipingPropertyFileSnitch
    ports:
      - "9042:9042"
    restart: unless-stopped

  keycloak:
    container_name: keycloak
    image: quay.io/keycloak/keycloak:26.1.0
    environment:
      - KC_BOOTSTRAP_ADMIN_USERNAME=admin
      - KC_BOOTSTRAP_ADMIN_PASSWORD=secret
    ports:
      - "8443:8443"
    command: [ "start-dev", "--http-port=8443" ]

  redis:
    image: redis:latest
    container_name: redis
    volumes:
      - redis_data:/data/cache
    ports:
      - "6379:6379"
    command: [ "redis-server" ]

volumes:
  vault-data:
    driver: local
  cassandra_data:
    driver: local
  zookeeper_data:
    driver: local
  kafka_data:
    driver: local
  postgres_data:
    driver: local
  redis_data:
    driver: local

networks:
  online-akim-bank-network:
    driver: bridge